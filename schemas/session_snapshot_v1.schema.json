{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "session_snapshot_v1",
  "type": "object",
  "required": [
    "schema_version",
    "session_snapshot_version",
    "session_snapshot_id",
    "pool_id",
    "generated_at",
    "locale",
    "seed",
    "question_count",
    "selector_policy",
    "questions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "session_snapshot_version": { "type": "string", "const": "session_snapshot.v1" },
    "session_snapshot_id": { "type": "string", "minLength": 1 },
    "pool_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "locale": { "type": "string", "enum": ["fr", "en", "nl"] },
    "seed": { "type": "string", "minLength": 1 },
    "question_count": { "type": "integer", "minimum": 1 },
    "selector_policy": {
      "type": "object",
      "required": ["version", "max_questions_per_taxon", "option_generation"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "const": "phase2a.selector.v1" },
        "max_questions_per_taxon": { "type": "integer", "const": 1 },
        "option_generation": { "type": "string", "const": "deferred_phase3" }
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "question_id",
          "question_index",
          "playable_item_id",
          "canonical_taxon_id",
          "media_asset_id",
          "scientific_name",
          "label",
          "label_source",
          "feedback_short",
          "media",
          "country_code",
          "options",
          "option_generation"
        ],
        "additionalProperties": false,
        "properties": {
          "question_id": { "type": "string", "minLength": 1 },
          "question_index": { "type": "integer", "minimum": 1 },
          "playable_item_id": { "type": "string", "minLength": 1 },
          "canonical_taxon_id": { "type": "string", "minLength": 1 },
          "media_asset_id": { "type": "string", "minLength": 1 },
          "scientific_name": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "label_source": { "type": "string", "enum": ["common_name", "scientific_name"] },
          "feedback_short": { "type": ["string", "null"] },
          "media": {
            "type": "object",
            "required": ["render_url", "attribution", "license"],
            "additionalProperties": false,
            "properties": {
              "render_url": { "type": "string", "minLength": 1 },
              "attribution": { "type": "string", "minLength": 1 },
              "license": { "type": ["string", "null"] }
            }
          },
          "country_code": { "type": "string", "enum": ["BE", "FR"] },
          "options": {
            "type": "array",
            "maxItems": 0
          },
          "option_generation": {
            "type": "object",
            "required": ["status", "reason"],
            "additionalProperties": false,
            "properties": {
              "status": { "type": "string", "const": "deferred_phase3" },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
