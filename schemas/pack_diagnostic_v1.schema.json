{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "pack_diagnostic_v1",
  "type": "object",
  "required": [
    "schema_version",
    "pack_diagnostic_version",
    "attempt_id",
    "pack_id",
    "revision",
    "attempted_at",
    "compilable",
    "reason_code",
    "thresholds",
    "measured",
    "deficits",
    "blocking_taxa"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "pack_diagnostic_version": {
      "type": "string",
      "const": "pack.diagnostic.v1"
    },
    "attempt_id": {
      "type": "string",
      "minLength": 1
    },
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "attempted_at": {
      "type": "string",
      "format": "date-time"
    },
    "compilable": {
      "type": "boolean"
    },
    "reason_code": {
      "type": "string",
      "enum": [
        "compilable",
        "no_playable_items",
        "insufficient_taxa_served",
        "insufficient_media_per_taxon",
        "insufficient_total_questions"
      ]
    },
    "thresholds": {
      "type": "object",
      "required": [
        "min_taxa_served",
        "min_media_per_taxon",
        "min_total_questions"
      ],
      "additionalProperties": false,
      "properties": {
        "min_taxa_served": {
          "type": "integer",
          "minimum": 1
        },
        "min_media_per_taxon": {
          "type": "integer",
          "minimum": 1
        },
        "min_total_questions": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "measured": {
      "type": "object",
      "required": [
        "requested_taxa_count",
        "taxa_served",
        "min_media_count_per_taxon",
        "total_playable_items",
        "questions_possible"
      ],
      "additionalProperties": false,
      "properties": {
        "requested_taxa_count": {
          "type": "integer",
          "minimum": 0
        },
        "taxa_served": {
          "type": "integer",
          "minimum": 0
        },
        "min_media_count_per_taxon": {
          "type": "integer",
          "minimum": 0
        },
        "total_playable_items": {
          "type": "integer",
          "minimum": 0
        },
        "questions_possible": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "deficits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "current",
          "required",
          "missing"
        ],
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "current": {
            "type": "integer",
            "minimum": 0
          },
          "required": {
            "type": "integer",
            "minimum": 1
          },
          "missing": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "blocking_taxa": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "canonical_taxon_id",
          "media_count",
          "missing_media_count"
        ],
        "additionalProperties": false,
        "properties": {
          "canonical_taxon_id": {
            "type": "string",
            "minLength": 1
          },
          "media_count": {
            "type": "integer",
            "minimum": 0
          },
          "missing_media_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
