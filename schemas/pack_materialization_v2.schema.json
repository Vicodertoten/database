{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "pack_materialization_v2",
  "type": "object",
  "required": [
    "schema_version",
    "pack_materialization_version",
    "materialization_id",
    "pack_id",
    "revision",
    "source_build_id",
    "created_at",
    "purpose",
    "ttl_hours",
    "expires_at",
    "question_count",
    "questions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "pack_materialization_version": {
      "type": "string",
      "const": "pack.materialization.v2"
    },
    "materialization_id": {
      "type": "string",
      "minLength": 1
    },
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "source_build_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "purpose": {
      "type": "string",
      "enum": ["assignment", "daily_challenge"]
    },
    "ttl_hours": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "expires_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "question_count": {
      "type": "integer",
      "minimum": 0
    },
    "questions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/materialized_question_v2"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "purpose": {
            "const": "assignment"
          }
        }
      },
      "then": {
        "properties": {
          "ttl_hours": {
            "type": "null"
          },
          "expires_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "purpose": {
            "const": "daily_challenge"
          }
        }
      },
      "then": {
        "properties": {
          "ttl_hours": {
            "type": "integer",
            "minimum": 1
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  ],
  "$defs": {
    "materialized_question_v2": {
      "type": "object",
      "required": [
        "position",
        "target_playable_item_id",
        "target_canonical_taxon_id",
        "options"
      ],
      "additionalProperties": false,
      "properties": {
        "position": {
          "type": "integer",
          "minimum": 1
        },
        "target_playable_item_id": {
          "type": "string",
          "minLength": 1
        },
        "target_canonical_taxon_id": {
          "type": "string",
          "minLength": 1
        },
        "options": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "contains": {
            "type": "object",
            "required": ["is_correct"],
            "properties": {
              "is_correct": {
                "const": true
              }
            }
          },
          "minContains": 1,
          "maxContains": 1,
          "items": {
            "$ref": "#/$defs/question_option"
          }
        }
      }
    },
    "question_option": {
      "type": "object",
      "required": [
        "option_id",
        "canonical_taxon_id",
        "taxon_label",
        "is_correct",
        "source",
        "reason_codes"
      ],
      "additionalProperties": false,
      "properties": {
        "option_id": {
          "type": "string",
          "minLength": 1
        },
        "canonical_taxon_id": {
          "type": "string",
          "minLength": 1
        },
        "taxon_label": {
          "type": "string",
          "minLength": 1
        },
        "is_correct": {
          "type": "boolean"
        },
        "playable_item_id": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "score": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "referenced_only": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "is_correct": {
                "const": false
              }
            },
            "required": ["is_correct"]
          },
          "then": {
            "properties": {
              "reason_codes": {
                "minItems": 1
              },
              "source": {
                "minLength": 1
              }
            }
          }
        }
      ]
    }
  }
}
