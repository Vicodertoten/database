{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "pack_spec_v1",
  "type": "object",
  "required": [
    "schema_version",
    "pack_spec_version",
    "pack_id",
    "revision",
    "latest_revision",
    "created_at",
    "parameters"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "pack_spec_version": {
      "type": "string",
      "const": "pack.spec.v1"
    },
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "latest_revision": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "parameters": {
      "type": "object",
      "required": [
        "canonical_taxon_ids",
        "difficulty_policy",
        "country_code",
        "location_bbox",
        "location_point",
        "location_radius_meters",
        "observed_from",
        "observed_to",
        "owner_id",
        "org_id",
        "visibility",
        "intended_use"
      ],
      "additionalProperties": false,
      "properties": {
        "canonical_taxon_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "difficulty_policy": {
          "type": "string",
          "enum": [
            "easy",
            "balanced",
            "hard",
            "mixed"
          ]
        },
        "country_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "location_bbox": {
          "type": [
            "object",
            "null"
          ],
          "required": [
            "min_longitude",
            "min_latitude",
            "max_longitude",
            "max_latitude"
          ],
          "additionalProperties": false,
          "properties": {
            "min_longitude": {
              "type": "number"
            },
            "min_latitude": {
              "type": "number"
            },
            "max_longitude": {
              "type": "number"
            },
            "max_latitude": {
              "type": "number"
            }
          }
        },
        "location_point": {
          "type": [
            "object",
            "null"
          ],
          "required": [
            "longitude",
            "latitude"
          ],
          "additionalProperties": false,
          "properties": {
            "longitude": {
              "type": "number"
            },
            "latitude": {
              "type": "number"
            }
          }
        },
        "location_radius_meters": {
          "type": [
            "number",
            "null"
          ]
        },
        "observed_from": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "observed_to": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "owner_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "org_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "visibility": {
          "type": "string",
          "enum": [
            "private",
            "org",
            "public"
          ]
        },
        "intended_use": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
